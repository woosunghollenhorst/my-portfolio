        "## Winter Cycling Preferences"
      ],
      "id": "fc10b66f"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "import matplotlib.pyplot as plt\n",
        "import numpy as np\n",
        "\n",
        "gadgets = ['Winter Tires', 'Earmuffs', 'Reflective Vest', 'Face Mask', \n",
        "           'Gloves', 'Rain Jacket', 'Water Bottle', 'Other']\n",
        "escapist = [14, 17, 15, 4, 1, 8, 7, 2]\n",
        "new_middle = [5, 3, 5, 8, 12, 5, 3, 3]\n",
        "high_achiever = [13, 8, 8, 8, 6, 7, 8, 0]\n",
        "movers = [1, 3, 5, 11, 5, 2, 1, 1]\n",
        "\n",
        "x = np.arange(len(gadgets))\n",
        "width = 0.2\n",
        "\n",
        "fig, ax = plt.subplots(figsize=(12, 6))\n",
        "ax.bar(x - 1.5*width, escapist, width, label='Escapist', color='#5bcefa')\n",
        "ax.bar(x - 0.5*width, new_middle, width, label='New Middle Class', color='#7c73ff')\n",
        "ax.bar(x + 0.5*width, high_achiever, width, label='High Achiever', color='#2ecc71')\n",
        "ax.bar(x + 1.5*width, movers, width, label='Movers & Shakers', color='#e74c3c')\n",
        "ax.set_ylabel('Number of Respondents')\n",
        "ax.set_title('Winter Cycling Gadget Preferences by Milieu')\n",
        "ax.set_xticks(x)\n",
        "ax.set_xticklabels(gadgets, rotation=30, ha='right')\n",
        "ax.legend()\n",
        "plt.tight_layout()\n",
        "plt.show()"
      ],
      "id": "662b713c",
      "execution_count": null,
      "outputs": []
    },
