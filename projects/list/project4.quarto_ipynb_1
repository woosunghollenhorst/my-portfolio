        "## Potential Market Population"
      ],
      "id": "c1d2d859"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "import matplotlib.pyplot as plt\n",
        "\n",
        "groups = ['High Achiever', 'Escapist', 'Movers & Shakers', \n",
        "          'New Middle Class', '18-24 Year Olds', 'Chinese Students']\n",
        "potential = [53728, 29314, 21429, 13619, 23137, 1780]\n",
        "colors = ['#5bcefa', '#7c73ff', '#2ecc71', '#f39c12', '#e74c3c', '#95a5a6']\n",
        "\n",
        "fig, ax = plt.subplots(figsize=(10, 5))\n",
        "bars = ax.barh(groups, potential, color=colors)\n",
        "ax.set_xlabel('Potential Market Population')\n",
        "ax.set_title('Estimated Market Potential by Target Group in Karlsruhe')\n",
        "ax.invert_yaxis()\n",
        "for bar, val in zip(bars, potential):\n",
        "    ax.text(bar.get_width() + 500, bar.get_y() + bar.get_height()/2,\n",
        "            f'{val:,}', va='center', color='white')\n",
        "plt.tight_layout()\n",
        "plt.show()"
      ],
