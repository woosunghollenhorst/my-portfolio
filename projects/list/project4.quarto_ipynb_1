        "## Survey: Interest by Milieu"
      ],
      "id": "8744524c"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "import matplotlib.pyplot as plt\n",
        "\n",
        "milieus = ['Movers &\\nShakers', 'High\\nAchiever', 'Escapist', 'New Middle\\nClass']\n",
        "interest = [69.23, 64.29, 62.75, 55.00]\n",
        "colors = ['#2ecc71', '#5bcefa', '#7c73ff', '#f39c12']\n",
        "\n",
        "fig, ax = plt.subplots(figsize=(10, 5))\n",
        "bars = ax.bar(milieus, interest, color=colors)\n",
        "ax.set_ylabel('Interest (%)')\n",
        "ax.set_title('Interest in Swapfiets Subscription by Milieu')\n",
        "ax.set_ylim(0, 100)\n",
        "for bar, val in zip(bars, interest):\n",
        "    ax.text(bar.get_x() + bar.get_width()/2, bar.get_height() + 2,\n",
        "            f'{val}%', ha='center', color='white')\n",
        "plt.tight_layout()\n",
        "plt.show()"
      ],
